pipeline {
    agent any

    tools {
        nodejs 'NodeJS-20'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Instalar dependencias') {
            steps {
                dir('app_backend') {
                    sh 'npm install'
                }
            }
        }

        stage('Rodar testes') {
            steps {
                dir('app_backend') {
                    sh 'npm test'
                }
            }
        }

        stage('Deploy') {
            steps {
                dir('app_backend') {
                    sh 'docker build -t c214-backend .'
                    sh 'docker stop backend || true'
                    sh 'docker rm backend || true'
                    sh 'docker run -d --name backend -p 3000:3000 c214-backend'
                }
            }
        }
    }

    post {
        success {
            echo 'Testes e deploy concluidos com sucesso!'
        }
        failure {
            echo 'Algum passo falhou. Verifique os logs acima.'
        }
    }
}